# Copy this file, rename the copy to exactly:  .env
# Paste keys after the = signs. At least one key required. Never share this file.

# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional model overrides (defaults set in src/config.ts)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4.1
# GOOGLE_MODEL=gemini-2.5-pro

# PORT=3000

# Optional: 🚀 Publish button (free web hosting for your generated apps)
# Get a token at https://app.netlify.com → User settings → Applications → New access token
NETLIFY_TOKEN=

# Optional locally, REQUIRED when deployed online (see DEPLOY-ONLINE.md):
# with this set, the platform shows a login page and requires this password.
ACCESS_PASSWORD=

# Phase 3: cloud database (see SETUP-SUPABASE.md). Without these,
# projects are stored as local JSON files (fine for solo use).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
