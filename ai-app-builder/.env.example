# ============================================================
# Copy this file and rename the copy to exactly:  .env
# Then paste your API keys after the = signs (no quotes, no spaces).
# You only NEED one key, but all three gives you all three AIs.
# NEVER share this file or post it online.
# ============================================================

# From https://console.anthropic.com  →  API Keys
ANTHROPIC_API_KEY=

# From https://platform.openai.com/api-keys
OPENAI_API_KEY=

# From https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: override which models are used (defaults are fine)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4.1
# GOOGLE_MODEL=gemini-2.5-pro

# Optional: change the port the app runs on
# PORT=3000
